{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": [
      "node"
    ],
    "paths": {
      "@analyzer/*": [
        "./src/analyzer/*"
      ],
      "@interfaces/*": [
        "./src/interfaces/*"
      ],
      "@paths/*": [
        "./src/paths/*"
      ],
      "@rules/*": [
        "./src/rules/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../app-contracts"
    }
  ]
}
