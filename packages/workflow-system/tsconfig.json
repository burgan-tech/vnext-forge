{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@connection/*": [
        "./src/connection/*"
      ],
      "@health/*": [
        "./src/health/*"
      ],
      "@schema/*": [
        "./src/schema/*"
      ],
      "@simulation/*": [
        "./src/simulation/*"
      ],
      "@templates/*": [
        "./src/templates/*"
      ],
      "@workflow-utils/*": [
        "./src/utils/*"
      ],
      "@validation/*": [
        "./src/validation/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
