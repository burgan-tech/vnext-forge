{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@csx/*": [
        "./src/csx/*"
      ],
      "@setup/*": [
        "./src/setup/*"
      ],
      "@editor-kit-types/*": [
        "./src/types/*"
      ],
      "@workflow/*": [
        "./src/workflow/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
