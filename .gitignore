# Dependencies
node_modules/
.pnpm-store/

# Build output
# Note: apps/extension/dist/ is NOT excluded here — vsce needs to include
# dist/vendor/ and dist/webview-ui/ in the VSIX. Use apps/extension/.gitignore
# to exclude only the compiled bundle.
apps/web/dist/
apps/server/dist/
packages/*/dist/
build/
.turbo/
vnext-flow-studio-web/node_modules

# Environment
# All .env files are ignored everywhere (root + workspaces).
# Sensible defaults for local development are baked into the application code,
# so a missing .env file is never fatal — the apps log a warning at startup
# telling the developer to create an .env file when overrides are needed.
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Cache
.cache/
*.tsbuildinfo


# CLAUDE
