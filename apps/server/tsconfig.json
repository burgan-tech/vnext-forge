{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@controllers/*": [
        "./src/controllers/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@middleware/*": [
        "./src/middleware/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@services/*": [
        "./src/services/*"
      ],
      "@server-types/*": [
        "./src/types/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ],
  "references": [
    {
      "path": "../../packages/vnext-types"
    },
    {
      "path": "../../packages/app-contracts"
    },
    {
      "path": "../../packages/workflow-system"
    },
    {
      "path": "../../packages/workspace-service"
    }
  ]
}
