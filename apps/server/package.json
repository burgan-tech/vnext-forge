{
  "name": "@vnext-forge-studio/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@burgan-tech/vnext-schema": "^0.0.39",
    "@burgan-tech/vnext-template": "^0.0.7",
    "@hono/node-server": "^1.19.12",
    "@vnext-forge-studio/app-contracts": "workspace:*",
    "@vnext-forge-studio/lsp-core": "workspace:*",
    "@vnext-forge-studio/services-core": "workspace:*",
    "@vnext-forge-studio/vnext-types": "workspace:*",
    "hono": "^4.12.10",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
