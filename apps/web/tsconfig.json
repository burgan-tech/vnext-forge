{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@app/*": ["./src/app/*"],
      "@pages/*": ["./src/pages/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"]
    },
    "noEmit": true
  },
  "include": ["src"],
  "references": [
    {
      "path": "../../packages/vnext-types"
    },
    {
      "path": "../../packages/app-contracts"
    },
    {
      "path": "../server"
    }
  ]
}
