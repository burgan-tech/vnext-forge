{
  "name": "vnext-forge-studio",
  "displayName": "vNext Forge Studio Extensions",
  "description": "Workflow designer for the vNext engine ecosystem",
  "version": "0.1.3",
  "publisher": "burgan-tech",
  "icon": "media/forge-tools.png",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:vnext.config.json",
    "onLanguage:csharp",
    "onCustomEditor:vnextForge.componentEditor",
    "onView:vnextForge.tools.globalSettings",
    "onView:vnextForge.tools.project",
    "onView:vnextForge.tools.createProject",
    "onView:vnextForge.tools.environments",
    "onView:vnextForge.tools.packageDeploy",
    "onCommand:vnextForge.open",
    "onCommand:vnextForge.openDesigner",
    "onCommand:vnextForge.openInTextEditor",
    "onCommand:vnextForge.createProject",
    "onCommand:vnextForge.createComponent",
    "onCommand:vnextForge.forgeCreateWorkflow",
    "onCommand:vnextForge.forgeCreateTask",
    "onCommand:vnextForge.forgeCreateSchema",
    "onCommand:vnextForge.forgeCreateView",
    "onCommand:vnextForge.forgeCreateFunction",
    "onCommand:vnextForge.forgeCreateExtension",
    "onCommand:vnextForge.openQuickRun"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/extension.js",
    "dist/vendor/**",
    "dist/webview-ui/**",
    "media/**",
    "snippets/**"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vnextForgeTools",
          "title": "vNext Forge Tools",
          "icon": "media/forge-tools.svg"
        }
      ]
    },
    "views": {
      "vnextForgeTools": [
        {
          "id": "vnextForge.tools.globalSettings",
          "name": "Settings"
        },
        {
          "id": "vnextForge.tools.project",
          "name": "Project",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "id": "vnextForge.tools.createProject",
          "name": "Create Project",
          "when": "!vnextForge.isVnextWorkspace"
        },
        {
          "id": "vnextForge.tools.environments",
          "name": "Environments",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "id": "vnextForge.tools.packageDeploy",
          "name": "Package Deploy",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "id": "vnextForge.tools.quickRun",
          "name": "Quick Run",
          "when": "vnextForge.isVnextWorkspace"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vnextForge.tools.createProject",
        "contents": "No vNext project detected in this workspace.\n\nCreate a new vNext project to get started.\n[Create Project](command:vnextForge.tools.createProjectFromSidebar)"
      },
      {
        "view": "vnextForge.tools.quickRun",
        "contents": "Start a workflow run to simulate and debug workflows.\n\n[▶ Open Quick Run](command:vnextForge.openQuickRun)"
      }
    ],
    "languages": [
      {
        "id": "csharp",
        "extensions": [
          ".csx"
        ],
        "aliases": [
          "C# Script",
          "csx"
        ]
      }
    ],
    "snippets": [
      {
        "language": "csharp",
        "path": "./snippets/csx.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "vnextForge.open",
        "title": "Open Designer",
        "category": "Forge"
      },
      {
        "command": "vnextForge.openDesigner",
        "title": "Forge: Open with vNext Forge",
        "category": "Forge"
      },
      {
        "command": "vnextForge.openInTextEditor",
        "title": "Forge: Open with Text Editor",
        "category": "Forge"
      },
      {
        "command": "vnextForge.createProject",
        "title": "Create vnext Project",
        "category": "Forge"
      },
      {
        "command": "vnextForge.createComponent",
        "title": "Create vnext Component",
        "category": "Forge"
      },
      {
        "command": "vnextForge.forgeCreateWorkflow",
        "title": "Forge: Workflow Create",
        "category": "Forge"
      },
      {
        "command": "vnextForge.forgeCreateTask",
        "title": "Forge: Task Create",
        "category": "Forge"
      },
      {
        "command": "vnextForge.forgeCreateSchema",
        "title": "Forge: Schema Create",
        "category": "Forge"
      },
      {
        "command": "vnextForge.forgeCreateView",
        "title": "Forge: View Create",
        "category": "Forge"
      },
      {
        "command": "vnextForge.forgeCreateFunction",
        "title": "Forge: Function Create",
        "category": "Forge"
      },
      {
        "command": "vnextForge.forgeCreateExtension",
        "title": "Forge: Extension Create",
        "category": "Forge"
      },
      {
        "command": "vnextForge.applyMaterialIconAssociations",
        "title": "Apply Material Icon Associations (User Settings)",
        "category": "Forge"
      },
      {
        "command": "vnextForge.removeMaterialIconAssociations",
        "title": "Remove Material Icon Associations (User Settings)",
        "category": "Forge"
      },
      {
        "command": "vnextForge.tools.changeSetting",
        "title": "Change Setting",
        "category": "Forge",
        "icon": "$(edit)"
      },
      {
        "command": "vnextForge.tools.validateProject",
        "title": "Validate Project",
        "category": "Forge",
        "icon": "$(check-all)"
      },
      {
        "command": "vnextForge.tools.buildRuntime",
        "title": "Build Runtime",
        "category": "Forge",
        "icon": "$(package)"
      },
      {
        "command": "vnextForge.tools.buildReference",
        "title": "Build Reference",
        "category": "Forge",
        "icon": "$(references)"
      },
      {
        "command": "vnextForge.tools.generateDocs",
        "title": "Generate Documents",
        "category": "Forge",
        "icon": "$(book)"
      },
      {
        "command": "vnextForge.tools.createProjectFromSidebar",
        "title": "Create vNext Project",
        "category": "Forge",
        "icon": "$(add)"
      },
      {
        "command": "vnextForge.tools.addEnvironment",
        "title": "Add Environment",
        "category": "Forge",
        "icon": "$(add)"
      },
      {
        "command": "vnextForge.tools.editEnvironment",
        "title": "Edit Environment",
        "category": "Forge",
        "icon": "$(edit)"
      },
      {
        "command": "vnextForge.tools.deleteEnvironment",
        "title": "Delete Environment",
        "category": "Forge",
        "icon": "$(trash)"
      },
      {
        "command": "vnextForge.tools.setActiveEnvironment",
        "title": "Set Active Environment",
        "category": "Forge",
        "icon": "$(check)"
      },
      {
        "command": "vnextForge.tools.switchEnvironment",
        "title": "Switch Environment",
        "category": "Forge"
      },
      {
        "command": "vnextForge.tools.checkHealth",
        "title": "Check Environment Health",
        "category": "Forge",
        "icon": "$(pulse)"
      },
      {
        "command": "vnextForge.tools.wfUpdateAll",
        "title": "Deploy All (wf update --all)",
        "category": "Forge",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "vnextForge.tools.wfUpdate",
        "title": "Deploy Changed (wf update)",
        "category": "Forge",
        "icon": "$(diff)"
      },
      {
        "command": "vnextForge.tools.wfCsxAll",
        "title": "CSX Update All (wf csx --all)",
        "category": "Forge",
        "icon": "$(file-code)"
      },
      {
        "command": "vnextForge.tools.installWfCli",
        "title": "Install Workflow CLI",
        "category": "Forge",
        "icon": "$(desktop-download)"
      },
      {
        "command": "vnextForge.openQuickRun",
        "title": "Quick Run",
        "category": "Forge",
        "icon": "$(play)"
      },
      {
        "command": "vnextForge.openQuickRunFromFile",
        "title": "Open Quick Run",
        "category": "Forge",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vnextForge.tools.addEnvironment",
          "when": "view == vnextForge.tools.environments",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vnextForge.tools.changeSetting",
          "when": "view == vnextForge.tools.globalSettings && viewItem == settingItem",
          "group": "inline"
        },
        {
          "command": "vnextForge.tools.validateProject",
          "when": "view == vnextForge.tools.project && viewItem == projectAction_validate",
          "group": "inline"
        },
        {
          "command": "vnextForge.tools.buildRuntime",
          "when": "view == vnextForge.tools.project && viewItem == projectAction_buildRuntime",
          "group": "inline"
        },
        {
          "command": "vnextForge.tools.buildReference",
          "when": "view == vnextForge.tools.project && viewItem == projectAction_buildReference",
          "group": "inline"
        },
        {
          "command": "vnextForge.tools.generateDocs",
          "when": "view == vnextForge.tools.project && viewItem == projectAction_generateDocs",
          "group": "inline"
        },
        {
          "command": "vnextForge.tools.setActiveEnvironment",
          "when": "view == vnextForge.tools.environments && viewItem == environment",
          "group": "inline@1"
        },
        {
          "command": "vnextForge.tools.editEnvironment",
          "when": "view == vnextForge.tools.environments && viewItem == environment",
          "group": "inline@2"
        },
        {
          "command": "vnextForge.tools.deleteEnvironment",
          "when": "view == vnextForge.tools.environments && viewItem == environment",
          "group": "inline@3"
        },
        {
          "command": "vnextForge.tools.checkHealth",
          "when": "view == vnextForge.tools.environments && viewItem == environment",
          "group": "inline@4"
        }
      ],
      "commandPalette": [
        {
          "command": "vnextForge.open",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.openDesigner",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.openInTextEditor",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.createProject"
        },
        {
          "command": "vnextForge.createComponent",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.forgeCreateWorkflow",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.forgeCreateTask",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.forgeCreateSchema",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.forgeCreateView",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.forgeCreateFunction",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.forgeCreateExtension",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.tools.changeSetting",
          "when": "false"
        },
        {
          "command": "vnextForge.tools.editEnvironment",
          "when": "false"
        },
        {
          "command": "vnextForge.tools.deleteEnvironment",
          "when": "false"
        },
        {
          "command": "vnextForge.tools.setActiveEnvironment",
          "when": "false"
        },
        {
          "command": "vnextForge.tools.checkHealth",
          "when": "false"
        },
        {
          "command": "vnextForge.tools.installWfCli",
          "when": "false"
        },
        {
          "command": "vnextForge.tools.generateDocs",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.openQuickRun",
          "when": "vnextForge.isVnextWorkspace"
        },
        {
          "command": "vnextForge.openQuickRunFromFile",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "vnextForge.openDesigner",
          "when": "vnextForge.isVnextWorkspace && resourceExtname == .json && resourcePath =~ /[\\\\/](Tasks|Views|Functions|Extensions|Workflows|Schemas)[\\\\/]/",
          "group": "navigation@1"
        },
        {
          "command": "vnextForge.openInTextEditor",
          "when": "vnextForge.isVnextWorkspace && resourceExtname == .json && resourcePath =~ /[\\\\/](Tasks|Views|Functions|Extensions|Workflows|Schemas)[\\\\/]/",
          "group": "navigation@2"
        },
        {
          "command": "vnextForge.forgeCreateWorkflow",
          "when": "vnextForge.isVnextWorkspace && explorerResourceIsFolder && resourcePath =~ /[\\\\/]Workflows([\\\\/][^\\\\/]+)?$/",
          "group": "1forge@5"
        },
        {
          "command": "vnextForge.forgeCreateTask",
          "when": "vnextForge.isVnextWorkspace && explorerResourceIsFolder && resourcePath =~ /[\\\\/]Tasks([\\\\/][^\\\\/]+)?$/",
          "group": "1forge@6"
        },
        {
          "command": "vnextForge.forgeCreateSchema",
          "when": "vnextForge.isVnextWorkspace && explorerResourceIsFolder && resourcePath =~ /[\\\\/]Schemas([\\\\/][^\\\\/]+)?$/",
          "group": "1forge@7"
        },
        {
          "command": "vnextForge.forgeCreateView",
          "when": "vnextForge.isVnextWorkspace && explorerResourceIsFolder && resourcePath =~ /[\\\\/]Views([\\\\/][^\\\\/]+)?$/",
          "group": "1forge@8"
        },
        {
          "command": "vnextForge.forgeCreateFunction",
          "when": "vnextForge.isVnextWorkspace && explorerResourceIsFolder && resourcePath =~ /[\\\\/]Functions([\\\\/][^\\\\/]+)?$/",
          "group": "1forge@9"
        },
        {
          "command": "vnextForge.forgeCreateExtension",
          "when": "vnextForge.isVnextWorkspace && explorerResourceIsFolder && resourcePath =~ /[\\\\/]Extensions([\\\\/][^\\\\/]+)?$/",
          "group": "1forge@10"
        },
        {
          "command": "vnextForge.openQuickRunFromFile",
          "when": "vnextForge.isVnextWorkspace && resourceExtname == .json && resourcePath =~ /[\\\\/]Workflows[\\\\/]/",
          "group": "navigation@3"
        }
      ],
      "editor/title/context": [
        {
          "command": "vnextForge.openDesigner",
          "when": "vnextForge.isVnextWorkspace && resourceExtname == .json && resourcePath =~ /[\\\\/](Tasks|Views|Functions|Extensions|Workflows|Schemas)[\\\\/]/",
          "group": "navigation@1"
        },
        {
          "command": "vnextForge.openInTextEditor",
          "when": "vnextForge.isVnextWorkspace && resourceExtname == .json && resourcePath =~ /[\\\\/](Tasks|Views|Functions|Extensions|Workflows|Schemas)[\\\\/]/",
          "group": "navigation@2"
        },
        {
          "command": "vnextForge.openQuickRunFromFile",
          "when": "vnextForge.isVnextWorkspace && resourceExtname == .json && resourcePath =~ /[\\\\/]Workflows[\\\\/]/",
          "group": "navigation@3"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "vnextForge.componentEditor",
        "displayName": "vnext-forge-studio Designer",
        "selector": [
          {
            "filenamePattern": "*.json"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "title": "vnext-forge-studio",
      "properties": {
        "vnextForge.lsp.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install the C# language server (csharp-ls or OmniSharp) when a vnext workspace is detected."
        },
        "vnextForge.lsp.enableNativeEditor": {
          "type": "boolean",
          "default": true,
          "description": "Enable C# IntelliSense and diagnostics for .csx files opened in VS Code's native editor (in addition to the designer's Monaco editor). Only active when the workspace contains vnext.config.json."
        },
        "vnextForge.vnextRuntimeUrl": {
          "type": "string",
          "default": "http://localhost:4201",
          "description": "Default base URL the runtime-proxy service points at. Can be overridden by the VNEXT_RUNTIME_URL env var."
        },
        "vnextForge.runtimeAllowedBaseUrls": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional base URLs the runtime-proxy is allowed to call. The default vnextRuntimeUrl is always implicitly allowed."
        },
        "vnextForge.allowRuntimeUrlOverride": {
          "type": "boolean",
          "default": false,
          "description": "When true, callers may override the runtime-proxy target via the runtimeUrl request parameter. Off by default to avoid SSRF-style misuse."
        },
        "vnextForge.runtimeRevalidationMinIntervalSeconds": {
          "type": "number",
          "default": 30,
          "description": "Minimum time (seconds) between background runtime revalidation requests issued by the designer UI."
        },
        "vnextForge.materialAssociations.managed": {
          "type": "object",
          "default": { "folders": [], "files": [] },
          "description": "Internal: tracks which entries vnext-forge-studio added to material-icon-theme.{folders,files}.associations so they can be safely removed without touching user-defined associations.",
          "properties": {
            "folders": { "type": "array", "items": { "type": "string" } },
            "files": { "type": "array", "items": { "type": "string" } }
          }
        },
        "vnextForge.quickRun.pollingRetryCount": {
          "type": "number",
          "default": 6,
          "description": "Number of polling retries for QuickRun state queries (awaiting stable status)."
        },
        "vnextForge.quickRun.pollingIntervalMs": {
          "type": "number",
          "default": 10,
          "description": "Interval in milliseconds between QuickRun polling attempts."
        }
      }
    }
  },
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "dev:host": "node esbuild.config.mjs --watch",
    "dev:webview": "vite build --watch --config webview-ui/vite.config.ts",
    "build": "npm run build:host && npm run build:webview",
    "sync-tab-icons": "node scripts/sync-component-tab-icons.mjs",
    "build:host": "npm run sync-tab-icons && node esbuild.config.mjs --production",
    "build:webview": "vite build --config webview-ui/vite.config.ts",
    "package": "vsce package --no-dependencies --allow-missing-repository --skip-license --allow-unused-files-pattern",
    "lint": "eslint .",
    "clean": "rm -rf dist *.vsix"
  },
  "dependencies": {
    "@burgan-tech/vnext-schema": "^0.0.39",
    "@burgan-tech/vnext-template": "^0.0.7",
    "@vnext-forge-studio/app-contracts": "workspace:*",
    "@vnext-forge-studio/designer-ui": "workspace:*",
    "@vnext-forge-studio/doc-gen": "workspace:*",
    "@vnext-forge-studio/lsp-core": "workspace:*",
    "@vnext-forge-studio/services-core": "workspace:*",
    "@vnext-forge-studio/vnext-types": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "vscode-languageclient": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "monaco-editor": "^0.55.1",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.25.12",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.2"
  }
}
